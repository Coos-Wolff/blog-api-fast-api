# Copy this file to .env.docker for use with docker compose.
# Compose does not auto-load this filename — run:
#   docker compose --env-file .env.docker up -d
APP_ENV=development
DEBUG=true
POSTGRES_USER=blog
POSTGRES_PASSWORD=blog
POSTGRES_DB=blogdb
DATABASE_URL=postgresql+asyncpg://blog:blog@postgres:5432/blogdb
JWT_SECRET_KEY=change-me
