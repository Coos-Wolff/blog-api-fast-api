# Auto detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Explicit text files
*.py text
*.toml text
*.md text
*.txt text
*.json text
*.yml text
*.yaml text
*.cfg text
*.ini text

# Windows scripts should keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary